<?xml version="1.0" encoding="UTF-8"?>
<!-- Kate / skylighting syntax highlighting for Catala (https://catala-lang.org/).
     Derived from the Pygments lexer at
       syntax_highlighting/{en,fr,pl}/pygments/<lang>_lexer/lexer.py
     The keyword sets below match the English lexer; for FR/PL pandoc would
     just need a parallel file with the localised keywords. -->

<!DOCTYPE language
[
<!-- Latin-1 + œ/Œ accented letters used in Catala identifiers (FR + EN). -->
<!ENTITY LOWER  "a-z\xe9\xe8\xe0\xe2\xf9\xee\xea\xe7œ">
<!ENTITY UPPER  "A-Z\xc9\xc8\xc0\xc2\xd9\xce\xca\xc7Œ">
<!ENTITY LETTER "&LOWER;&UPPER;">
<!ENTITY LIDENT "[&LOWER;][&LETTER;0-9_']*">
<!ENTITY UIDENT "[&UPPER;][&LETTER;0-9_']*">
]>
<language name="Catala"
          extensions="*.catala_en"
          mimetype="text/x-catala"
          section="Sources"
          version="1"
          priority="10"
          kateversion="5.79" >

  <highlighting>

    <!-- Catala reserved keywords + declaration/control keywords.
         Pygments separates them as Keyword.Reserved vs Keyword.Declaration,
         but both render with the same dsKeyword style, so we collapse them. -->
    <list name="Keywords">
      <item>match</item>
      <item>fixed</item>
      <item>by</item>
      <item>down</item>
      <item>up</item>
      <item>varies</item>
      <item>with</item>
      <item>let</item>
      <item>in</item>
      <item>scope</item>
      <item>declaration</item>
      <item>includes</item>
      <item>content</item>
      <item>type</item>
      <item>rule</item>
      <item>condition</item>
      <item>data</item>
      <item>consequence</item>
      <item>fulfilled</item>
      <item>equals</item>
      <item>assertion</item>
      <item>definition</item>
      <item>state</item>
      <item>label</item>
      <item>exception</item>
      <item>anything</item>
      <item>context</item>
      <item>input</item>
      <item>output</item>
      <item>internal</item>
      <item>contains</item>
      <item>number</item>
      <item>sum</item>
      <item>exists</item>
      <item>for</item>
      <item>all</item>
      <item>of</item>
      <item>if</item>
      <item>then</item>
      <item>else</item>
      <item>is</item>
      <item>among</item>
      <item>maximum</item>
      <item>minimum</item>
      <item>round</item>
      <item>combine</item>
      <item>to</item>
      <item>initially</item>
      <item>impossible</item>
    </list>

    <list name="Constants">
      <item>true</item>
      <item>false</item>
    </list>

    <list name="Types">
      <item>structure</item>
      <item>enumeration</item>
      <item>integer</item>
      <item>boolean</item>
      <item>date</item>
      <item>duration</item>
      <item>money</item>
      <item>code_location</item>
      <item>decimal</item>
    </list>

    <!-- Boolean / arithmetic word operators + duration units. -->
    <list name="Word Operators">
      <item>not</item>
      <item>or</item>
      <item>xor</item>
      <item>and</item>
      <item>year</item>
      <item>month</item>
      <item>day</item>
    </list>

    <contexts>

      <context name="Code" lineEndContext="#stay" attribute="Lowercase Identifier">

        <!-- Comments. Catala has `# ...` line comments and `#[ ... ]` block
             attribute-comments. -->
        <Detect2Chars char="#" char1="[" context="Attribute Comment" attribute="Comment" beginRegion="comment" />
        <RegExpr String="#.*$" context="#stay" attribute="Comment" />

        <!-- Date literals: |YYYY-MM-DD| -->
        <RegExpr String="\|[0-9]+-[0-9]+-[0-9]+\|" context="#stay" attribute="Date" />

        <!-- Multi-word keywords (tried before single-word `with`, `condition`,
             `list`, `optional`, ...). -->
        <RegExpr String="with\s+pattern\b"   context="#stay" attribute="Keyword" />
        <RegExpr String="but\s+replace\b"    context="#stay" attribute="Keyword" />
        <RegExpr String="we\s+have\b"        context="#stay" attribute="Keyword" />
        <RegExpr String="depends\s+on\b"     context="#stay" attribute="Keyword" />
        <RegExpr String="under\s+condition\b" context="#stay" attribute="Keyword" />
        <RegExpr String="such\s+that\b"      context="#stay" attribute="Keyword" />
        <RegExpr String="list\s+empty\b"     context="#stay" attribute="Keyword" />
        <RegExpr String="map\s+each\b"       context="#stay" attribute="Keyword" />
        <RegExpr String="list\s+of\b"        context="#stay" attribute="Type" />
        <RegExpr String="optional\s+of\b"    context="#stay" attribute="Type" />

        <!-- Single-word keywords / constants / types / word operators. -->
        <keyword String="Keywords"       context="#stay" attribute="Keyword" />
        <keyword String="Constants"      context="#stay" attribute="Constant" />
        <keyword String="Types"          context="#stay" attribute="Type" />
        <keyword String="Word Operators" context="#stay" attribute="Operator" />

        <!-- Numeric literals: integer or decimal-with-comma. -->
        <RegExpr String="[0-9]+(,[0-9]*)?" context="#stay" attribute="Decimal" />

        <!-- Compound operators (typed arithmetic / comparison suffixes
             `.` decimal, `@` date, `^` duration, `$` money). -->
        <RegExpr String="-&gt;|--|&gt;=\.|&lt;=\.|&gt;=@|&lt;=@|&gt;=\$|&lt;=\$|&gt;=\^|&lt;=\^|&gt;\.|&lt;\.|&gt;@|&lt;@|&gt;\$|&lt;\$|&gt;\^|&lt;\^|&gt;=|&lt;=|\+\.|\+@|\+\^|\+\$|-\.|-@|-\^|-\$|\*\.|\*@|\*\^|\*\$|/\.|/@|/\$" context="#stay" attribute="Operator" />

        <!-- Single-char operators / punctuation. -->
        <AnyChar String="+-*/!&gt;&lt;=$€%;.,:()[]{}" context="#stay" attribute="Operator" />

        <!-- Identifiers. Lowercase = variable / scope / field;
                          Uppercase = type / constructor / module. -->
        <RegExpr String="&UIDENT;" context="#stay" attribute="Uppercase Identifier" />
        <RegExpr String="&LIDENT;" context="#stay" attribute="Lowercase Identifier" />

      </context>

      <context name="Attribute Comment" lineEndContext="#stay" attribute="Comment">
        <RegExpr String="\\." context="#stay" attribute="Comment" />
        <DetectChar char="]" context="#pop" attribute="Comment" endRegion="comment" />
      </context>

    </contexts>

    <itemDatas>
      <itemData name="Lowercase Identifier" defStyleNum="dsVariable" />
      <itemData name="Uppercase Identifier" defStyleNum="dsFunction" />
      <itemData name="Keyword"              defStyleNum="dsKeyword"  />
      <itemData name="Type"                 defStyleNum="dsDataType" />
      <itemData name="Constant"             defStyleNum="dsConstant" />
      <itemData name="Operator"             defStyleNum="dsOperator" />
      <itemData name="Decimal"              defStyleNum="dsDecVal"   />
      <itemData name="Date"                 defStyleNum="dsDecVal"   />
      <itemData name="Comment"              defStyleNum="dsComment"  />
    </itemDatas>
  </highlighting>

  <general>
    <keywords casesensitive="true" />
    <comments>
      <comment name="singleLine" start="#" />
    </comments>
  </general>
</language>
<!-- kate: space-indent on; indent-width 2; replace-tabs on; -->

```catala
declaration f
  content boolean
  depends on x content integer
  equals
    if x = 0 then false else true

declaration scope A:
  input i content boolean
  output f_scope_a content boolean depends on x content integer
  output a_A content boolean

scope A:
  definition f_scope_a of x equals
    match (if x = 3 then Absent else Present content 3) with pattern
    -- Absent : false
    -- anything : true
  definition a_A equals i

#[test]
declaration scope T:
  output a_T content boolean
  ssv scope A
  internal g content boolean depends on x content integer
  output res content A

scope T:
  definition ssv.i equals let zzz equals 333 in true

  label base
  definition a_T equals ssv.a_A

  label one exception base
  definition a_T
  under condition 42 = 42
  consequence equals
    not ssv.a_A

  label two exception one
  definition a_T
  under condition 43 > 43
  consequence equals
    not (ssv.f_scope_a of 2 or ssv.a_A)

  definition g of x equals
    match (if x = 3 then Absent else Present content 3) with pattern
    -- Absent : false
    -- anything : true

  definition res equals
    output of A with { -- i: f of 2 or g of 3 }

  assertion 42 = 42
```


glob1 = (Decimal('1103/25'))

def glob3(x:Money) -> Decimal:
    return (Decimal(x) + Decimal('10'))

def glob4(x:Money, y:Decimal) -> Decimal:
    return ((Decimal(x) * y) + Decimal('10'))

def glob5_init() -> Decimal:
    x = ((Decimal(Integer(2)) * Decimal('3')))
    y = (Decimal('1000'))
    return (x * y)

glob5 = (glob5_init())

glob2 = (A(y = (glob1 >= Decimal('30')), z = (Decimal('123') * Decimal('17'))))

def s2(s2_in:S2In) -> S2:
    a__1 = (Option(CatalaTuple((glob3(Money('44.00')) + Decimal('100')), loc[5])))
    if a__1.value is not None:
        a = (a__1.value[0])
    else:
        raise NoValue(loc[4])
    return S2(a = a)

def s3(s3_in:S3In) -> S3:
    a__1 = (Option(CatalaTuple((Decimal('50') + glob4(Money('44.00'), Decimal('55'))), loc[7])))
    if a__1.value is not None:
        a = (a__1.value[0])
    else:
        raise NoValue(loc[6])
    return S3(a = a)

def s4(s4_in:S4In) -> S4:
    a__1 = (Option(CatalaTuple((glob5 + Decimal('1')), loc[9])))
    if a__1.value is not None:
        a = (a__1.value[0])
    else:
        raise NoValue(loc[8])
    return S4(a = a)

def s(s_in:SIn) -> S:
    a__1 = (Option(CatalaTuple((glob1 * glob1), loc[2])))
    if a__1.value is not None:
        a = (a__1.value[0])
    else:
        raise NoValue(loc[0])
    b__1 = (Option(CatalaTuple(glob2, loc[3])))
    if b__1.value is not None:
        b = (b__1.value[0])
    else:
        raise NoValue(loc[1])
    return S(a = a, b = b)


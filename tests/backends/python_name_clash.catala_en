This test exposes a name clash between the scope function (`ScopeName,`
rewritten to `scope_name`) and the scope variable `scope_name`.

```catala
declaration scope SomeNâme:
  input i content integer
  output o content integer

scope SomeNâme:
  definition o equals i + 1

#[test]
declaration scope B:
  output some_nâme scope SomeNâme

scope B:
  definition some_nâme.i equals 1
```

```catala-test-cli
$ catala python
# This file has been generated by the Catala compiler, do not edit!

from catala_runtime import *
from typing import Any, List, Callable, Tuple
from enum import Enum
from sys import stderr
from . import Stdlib_en as stdlib_en
from . import Date_en as date_en
from . import List_en as list_en
from . import Duration_en as duration_en
from . import MonthYear_en as month_year_en
from . import Period_en as period_en
from . import Money_en as money_en
from . import Integer_en as integer_en
from . import Decimal_en as decimal_en

class SomeName(CatalaStruct):
    __slots__ = ('o')
    o: Integer
    name = 'SomeNâme'
    fields = {
        'o': 'o', # content Integer
    }

class B(CatalaStruct):
    __slots__ = ('some_name')
    some_name: SomeName
    name = 'B'
    fields = {
        'some_name': 'some_nâme', # content SomeName
    }

class BIn(CatalaStruct):
    __slots__ = ()
    name = 'B_in'
    fields = {
    }

class SomeNameIn(CatalaStruct):
    __slots__ = ('i_in')
    i_in: Integer
    name = 'SomeNâme_in'
    fields = {
        'i_in': 'i_in', # content Integer
    }


loc = (Array([SourcePosition(filename="tests/backends/python_name_clash.catala_en", start_line=7, start_column=10, end_line=7, end_column=11, law_headings=[]),
              SourcePosition(filename="tests/backends/python_name_clash.catala_en", start_line=10, start_column=23, end_line=10, end_column=28, law_headings=[]),
              SourcePosition(filename="tests/backends/python_name_clash.catala_en", start_line=17, start_column=14, end_line=17, end_column=25, law_headings=[]),
              SourcePosition(filename="tests/backends/python_name_clash.catala_en", start_line=17, start_column=33, end_line=17, end_column=34, law_headings=[])]))

def some_name(some_name_in:SomeNameIn) -> SomeName:
    i = (some_name_in.i_in)
    o__1 = (Option(CatalaTuple((i + Integer(1)), loc[1])))
    if o__1.value is not None:
        o = (o__1.value[0])
    else:
        raise NoValue(loc[0])
    return SomeName(o = o)

def b(b_in:BIn) -> B:
    result__2 = (Option(CatalaTuple(Integer(1), loc[3])))
    if result__2.value is not None:
        result__1 = (result__2.value[0])
    else:
        raise NoValue(loc[2])
    result = (some_name(SomeNameIn(i_in = result__1)))
    result__3 = (SomeName(o = result.o))
    if Bool(True):
        some_name__1 = (result__3)
    else:
        some_name__1 = (result__3)
    return B(some_name = some_name__1)

# Automatic Catala tests
if __name__ == "__main__":
  b_test = (b(BIn()))
  print("/x1b[32m[RESULT]/x1b[m Scope B executed successfully.", file=stderr)
  print(b_test)
```
The above should *not* show `some_name = temp_some_name`, but instead `some_name_1 = ...`
